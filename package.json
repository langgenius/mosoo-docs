{
  "name": "mosoo-docs",
  "version": "0.0.0",
  "type": "module",
  "description": "Open-source Mosoo API documentation built with Fumadocs.",
  "private": true,
  "scripts": {
    "build": "npm run openapi:pages && npm run test:seo && next build && node scripts/prepare-worker-assets.mjs",
    "dev": "next dev",
    "start": "serve out",
    "types:check": "fumadocs-mdx && next typegen && tsc --noEmit",
    "postinstall": "fumadocs-mdx",
    "lint": "eslint",
    "test:seo": "node --test tests/*.test.mjs && tsx --test tests/*.test.ts",
    "openapi:check": "node scripts/sync-openapi-specs.mjs check",
    "openapi:pages": "node scripts/generate-openapi-pages.mjs",
    "openapi:sync": "node scripts/sync-openapi-specs.mjs write && npm run openapi:pages",
    "deploy": "npm run build && wrangler deploy"
  },
  "dependencies": {
    "@orama/orama": "^3.1.18",
    "cnfast": "^0.0.8",
    "fumadocs-core": "16.10.7",
    "fumadocs-mdx": "15.0.13",
    "fumadocs-openapi": "^11.0.6",
    "fumadocs-ui": "16.10.7",
    "lucide-react": "^1.21.0",
    "next": "16.2.9",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "shiki": "^4.3.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.1",
    "@types/mdx": "^2.0.14",
    "@types/node": "^26.0.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.4",
    "eslint-config-next": "16.2.9",
    "postcss": "^8.5.15",
    "serve": "^14.2.6",
    "tailwindcss": "^4.3.1",
    "tsx": "^4.23.1",
    "typescript": "^6.0.3",
    "wrangler": "^4.106.0"
  }
}
